# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database (defaults to local SQLite) ---
# DATABASE_URL=postgresql://user:pass@host:5432/tightburrito

# --- Clerk auth (omit for anonymous-only mode in dev) ---
# CLERK_JWKS_URL=https://YOUR-CLERK-INSTANCE.clerk.accounts.dev/.well-known/jwks.json
# CLERK_DEV_USER_ID=dev-user-1   # bypasses JWT verification for local work

# --- Cloudflare R2 (image storage; if unset, image_url falls back to a placeholder) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=tightburrito
# R2_PUBLIC_URL=https://burritos.example.com

# --- CORS ---
# Comma-separated additional allowed origins for production frontend(s)
# FRONTEND_URL=https://tightburrito.vercel.app
